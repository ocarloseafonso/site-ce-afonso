<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; frame-src https://www.google.com;"
</IfModule>

Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Redirecionar index.html para a raiz (/) 
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^/]+/)*index\.html\ HTTP/
  RewriteRule ^(([^/]+/)*)index\.html$ /$1 [R=301,L]

  # 2. Redirecionar Chamada DIRETA de .html para URL limpa (ex: sobre.html -> sobre)
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^/]+/)*([^.]+)\.html\ HTTP/
  RewriteRule ^(([^/]+/)*)([^.]+)\.html$ /$1$3 [R=301,L]

  # 3. Remover barras finais (ex: /blog/ -> /blog) para evitar de entrar em pastas mortas
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [R=301,L]

  # 4. Resolver URLs limpas de volta para os arquivos .html internamente (Ignorando colisões com pastas)
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>
